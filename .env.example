# ==========================================================================
# Variáveis de ambiente do servidor (backend guardião). Ver DEPLOY.md.
# Em produção (Coolify/Docker) defina estas variáveis no painel — elas NÃO são
# injetadas automaticamente por nenhum ambiente.
# ==========================================================================

# OBRIGATÓRIAS
# ------------
# Credencial do Firebase Admin SDK (JSON da service account, em uma linha).
# Console Firebase → Configurações → Contas de serviço → Gerar nova chave privada.
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"...","private_key":"..."}'

# Segredo para assinar os tokens de sessão (>= 32 caracteres aleatórios).
# Gere com: openssl rand -base64 48
SESSION_SECRET="troque-por-uma-string-aleatoria-longa"

# OPCIONAIS
# ---------
# GEMINI_API_KEY: melhora a leitura de comprovantes em fotos ruins e habilita PDF
# escaneado. NÃO é obrigatória — sem ela, o motor interno de OCR (Tesseract) assume.
GEMINI_API_KEY=""

# Telegram (armazenamento de anexos). Rotacione o token no @BotFather.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# APP_URL: URL pública onde o app está hospedado (links self-referenciais).
APP_URL=""
